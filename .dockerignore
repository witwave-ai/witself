# Keep the Docker build context to the Go module that the image builds. The
# builder stage only needs go.mod/go.sum, the cmd/, and internal/ trees; the
# Dockerfiles cross-compile statically with CGO disabled.

# VCS and tooling
.git
.github
.gitignore
.dockerignore

# Non-build assets: docs, charts, infra, and images themselves
docs
charts
infra
images

# Top-level repo docs (not needed inside the image build)
README.md
CONTRIBUTING.md
SECURITY.md
LICENSE

# Build output and local artifacts
bin
dist
*.test
*.out
coverage.*

# Editors / OS
.idea
.vscode
.DS_Store
Thumbs.db
*.swp
*~

# Local env / credentials (never ship into a build context)
.env
*.local
*.tfvars
*.token

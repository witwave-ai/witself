{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "witself chart values",
  "type": "object",
  "required": ["image", "backend", "features", "agentEmail", "avatar", "worker", "server", "health", "metrics", "service"],
  "allOf": [
    {
      "if": {
        "properties": {
          "worker": {
            "properties": { "enabled": { "const": true } },
            "required": ["enabled"]
          }
        },
        "required": ["worker"]
      },
      "then": {
        "properties": {
          "database": {
            "properties": {
              "existingSecret": {
                "properties": { "name": { "minLength": 1 } },
                "required": ["name"]
              }
            },
            "required": ["existingSecret"]
          }
        },
        "required": ["database"]
      }
    }
  ],
  "properties": {
    "replicaCount": { "type": "integer", "minimum": 0 },
    "minReadySeconds": { "type": "integer", "minimum": 0 },
    "strategy": {
      "type": "object",
      "required": ["type", "rollingUpdate"],
      "not": {
        "properties": {
          "rollingUpdate": {
            "properties": {
              "maxUnavailable": { "enum": [0, "0%"] },
              "maxSurge": { "enum": [0, "0%"] }
            },
            "required": ["maxUnavailable", "maxSurge"]
          }
        },
        "required": ["rollingUpdate"]
      },
      "properties": {
        "type": { "type": "string", "enum": ["RollingUpdate"] },
        "rollingUpdate": {
          "type": "object",
          "required": ["maxUnavailable", "maxSurge"],
          "properties": {
            "maxUnavailable": {
              "oneOf": [
                { "type": "integer", "minimum": 0 },
                { "type": "string", "pattern": "^(100|[0-9]{1,2})%$" }
              ]
            },
            "maxSurge": {
              "oneOf": [
                { "type": "integer", "minimum": 0 },
                { "type": "string", "pattern": "^(100|[0-9]{1,2})%$" }
              ]
            }
          }
        }
      }
    },
    "image": {
      "type": "object",
      "required": ["repository"],
      "properties": {
        "repository": { "type": "string", "minLength": 1 },
        "tag": { "type": "string" },
        "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] }
      }
    },
    "backend": {
      "type": "object",
      "required": ["kind"],
      "properties": {
        "kind": { "type": "string", "minLength": 1 }
      }
    },
    "features": {
      "type": "object",
      "required": ["factDeletion"],
      "properties": {
        "factDeletion": {
          "type": "object",
          "required": ["enabled"],
          "properties": {
            "enabled": { "type": "boolean" }
          }
        }
      }
    },
    "agentEmail": {
      "type": "object",
      "additionalProperties": false,
      "required": ["receivePilot"],
      "properties": {
        "receivePilot": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled", "domain", "audience", "realmID", "agentIDs", "retryCanaryAgentID", "relayPublicKeysJSON", "relayReplayWindow"],
          "properties": {
            "enabled": { "type": "boolean" },
            "domain": { "type": "string" },
            "audience": { "type": "string" },
            "realmID": { "type": "string" },
            "agentIDs": {
              "type": "array",
              "uniqueItems": true,
              "items": { "type": "string", "pattern": "^agent_[a-z2-7]{16}$" }
            },
            "retryCanaryAgentID": {
              "type": "string",
              "pattern": "^$|^agent_[a-z2-7]{16}$"
            },
            "relayPublicKeysJSON": { "type": "string" },
            "relayReplayWindow": { "type": "string", "minLength": 1 }
          },
          "allOf": [
            {
              "if": {
                "properties": { "enabled": { "const": true } },
                "required": ["enabled"]
              },
              "then": {
                "properties": {
                  "domain": {
                    "minLength": 1,
                    "maxLength": 253,
                    "pattern": "^[a-z0-9]([a-z0-9.-]*[a-z0-9])?$"
                  },
                  "audience": {
                    "minLength": 1,
                    "maxLength": 128,
                    "pattern": "^[a-z]([a-z0-9-]*[a-z0-9])?$"
                  },
                  "realmID": { "pattern": "^realm_[a-z2-7]{16}$" },
                  "agentIDs": { "minItems": 5, "maxItems": 10 },
                  "relayPublicKeysJSON": { "minLength": 2 }
                }
              }
            }
          ]
        }
      }
    },
    "avatar": {
      "type": "object",
      "additionalProperties": false,
      "required": ["payloadCompaction"],
      "properties": {
        "payloadCompaction": {
          "type": "object",
          "required": ["enabled"],
          "properties": {
            "enabled": { "type": "boolean" }
          }
        }
      }
    },
    "worker": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "replicaCount",
        "minReadySeconds",
        "strategy",
        "terminationGracePeriodSeconds",
        "health",
        "metrics",
        "probes",
        "resources",
        "podDisruptionBudget",
        "networkPolicy",
        "podAnnotations",
        "podLabels",
        "nodeSelector",
        "tolerations",
        "affinity",
        "topologySpreadConstraints",
        "avatarStyleRollout",
        "transcriptRetention"
      ],
      "properties": {
        "enabled": { "type": "boolean" },
        "replicaCount": { "type": "integer", "minimum": 1 },
        "minReadySeconds": { "type": "integer", "minimum": 0 },
        "strategy": {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "rollingUpdate"],
          "not": {
            "properties": {
              "rollingUpdate": {
                "properties": {
                  "maxUnavailable": { "enum": [0, "0%"] },
                  "maxSurge": { "enum": [0, "0%"] }
                },
                "required": ["maxUnavailable", "maxSurge"]
              }
            },
            "required": ["rollingUpdate"]
          },
          "properties": {
            "type": { "type": "string", "enum": ["RollingUpdate"] },
            "rollingUpdate": {
              "type": "object",
              "additionalProperties": false,
              "required": ["maxUnavailable", "maxSurge"],
              "properties": {
                "maxUnavailable": {
                  "oneOf": [
                    { "type": "integer", "minimum": 0 },
                    { "type": "string", "pattern": "^(100|[0-9]{1,2})%$" }
                  ]
                },
                "maxSurge": {
                  "oneOf": [
                    { "type": "integer", "minimum": 0 },
                    { "type": "string", "pattern": "^(100|[0-9]{1,2})%$" }
                  ]
                }
              }
            }
          }
        },
        "terminationGracePeriodSeconds": { "type": "integer", "minimum": 0 },
        "health": {
          "type": "object",
          "additionalProperties": false,
          "required": ["port"],
          "properties": {
            "port": { "type": "integer", "minimum": 1, "maximum": 65535 }
          }
        },
        "metrics": {
          "type": "object",
          "additionalProperties": false,
          "required": ["port", "path", "service", "serviceMonitor", "podMonitor"],
          "properties": {
            "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
            "path": { "const": "/metrics" },
            "service": {
              "type": "object",
              "additionalProperties": false,
              "required": ["enabled", "annotations"],
              "properties": {
                "enabled": { "type": "boolean" },
                "annotations": {
                  "type": "object",
                  "additionalProperties": { "type": "string" }
                }
              }
            },
            "serviceMonitor": {
              "type": "object",
              "additionalProperties": false,
              "required": ["enabled", "interval", "scrapeTimeout", "labels", "relabelings", "metricRelabelings"],
              "properties": {
                "enabled": { "type": "boolean" },
                "interval": { "type": "string", "minLength": 1 },
                "scrapeTimeout": { "type": "string", "minLength": 1 },
                "labels": { "type": "object" },
                "relabelings": { "type": "array" },
                "metricRelabelings": { "type": "array" }
              }
            },
            "podMonitor": {
              "type": "object",
              "additionalProperties": false,
              "required": ["enabled", "interval", "scrapeTimeout", "labels"],
              "properties": {
                "enabled": { "type": "boolean" },
                "interval": { "type": "string", "minLength": 1 },
                "scrapeTimeout": { "type": "string", "minLength": 1 },
                "labels": { "type": "object" }
              }
            }
          }
        },
        "probes": {
          "type": "object",
          "additionalProperties": false,
          "required": ["liveness", "readiness", "startup"],
          "properties": {
            "liveness": { "$ref": "#/definitions/workerProbeWithDelay" },
            "readiness": { "$ref": "#/definitions/workerProbeWithDelay" },
            "startup": { "$ref": "#/definitions/workerProbe" }
          }
        },
        "resources": { "type": "object" },
        "podDisruptionBudget": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled", "minAvailable"],
          "properties": {
            "enabled": { "type": "boolean" },
            "minAvailable": {
              "oneOf": [
                { "type": "integer", "minimum": 0 },
                { "type": "string", "pattern": "^(100|[0-9]{1,2})%$" }
              ]
            }
          }
        },
        "networkPolicy": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled", "metricsFrom"],
          "properties": {
            "enabled": { "type": "boolean" },
            "metricsFrom": { "type": "array" }
          }
        },
        "podAnnotations": { "type": "object" },
        "podLabels": { "type": "object" },
        "nodeSelector": { "type": "object" },
        "tolerations": { "type": "array" },
        "affinity": { "type": "object" },
        "topologySpreadConstraints": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["maxSkew", "topologyKey", "whenUnsatisfiable"],
            "properties": {
              "maxSkew": { "type": "integer", "minimum": 1 },
              "topologyKey": { "type": "string", "minLength": 1 },
              "whenUnsatisfiable": {
                "type": "string",
                "enum": ["DoNotSchedule", "ScheduleAnyway"]
              },
              "labelSelector": { "type": "object" },
              "minDomains": { "type": "integer", "minimum": 1 },
              "nodeAffinityPolicy": { "type": "string", "enum": ["Honor", "Ignore"] },
              "nodeTaintsPolicy": { "type": "string", "enum": ["Honor", "Ignore"] },
              "matchLabelKeys": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              }
            }
          }
        },
        "avatarStyleRollout": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled", "batchSize", "interval", "batchTimeout"],
          "properties": {
            "enabled": { "type": "boolean" },
            "batchSize": { "type": "integer", "minimum": 1, "maximum": 1000 },
            "interval": {
              "type": "string",
              "pattern": "^((1[0-9]{2}|[2-9][0-9]{2}|[1-9][0-9]{3,5}|[12][0-9]{6}|3[0-5][0-9]{5}|3600000)ms|([1-9]|[1-9][0-9]|[1-9][0-9]{2}|[12][0-9]{3}|3[0-5][0-9]{2}|3600)s|([1-9]|[1-5][0-9]|60)m|1h)$"
            },
            "batchTimeout": {
              "type": "string",
              "pattern": "^(([1-9][0-9]{2,4}|[12][0-9]{5}|300000)ms|([1-9]|[1-9][0-9]|[12][0-9]{2}|300)s|[1-5]m)$"
            }
          }
        },
        "transcriptRetention": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled", "mode", "batchSize", "interval", "batchTimeout"],
          "properties": {
            "enabled": { "type": "boolean" },
            "mode": { "type": "string", "enum": ["preview", "enforce"] },
            "batchSize": { "type": "integer", "minimum": 1, "maximum": 1000 },
            "interval": {
              "type": "string",
              "pattern": "^(([1-9]|[1-9][0-9]|[1-9][0-9]{2}|1[0-3][0-9]{2}|14[0-3][0-9]|1440)m|([1-9]|1[0-9]|2[0-4])h)$"
            },
            "batchTimeout": {
              "type": "string",
              "pattern": "^(([1-9][0-9]{3}|[1-9][0-9]{4}|[12][0-9]{5}|300000)ms|([1-9]|[1-9][0-9]|[12][0-9]{2}|300)s|[1-5]m)$"
            }
          }
        }
      }
    },
    "transcriptRetention": false,
    "database": {
      "type": "object",
      "properties": {
        "existingSecret": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "urlKey": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "bootstrap": {
      "type": "object",
      "properties": {
        "tokenFile": { "type": "string", "minLength": 1 },
        "existingSecret": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "tokenKey": { "type": "string", "minLength": 1 },
            "ttlKey": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "server": {
      "type": "object",
      "required": ["port"],
      "properties": { "port": { "type": "integer", "minimum": 1, "maximum": 65535 } }
    },
    "health": {
      "type": "object",
      "required": ["port"],
      "properties": { "port": { "type": "integer", "minimum": 1, "maximum": 65535 } }
    },
    "metrics": {
      "type": "object",
      "required": ["enabled", "port"],
      "properties": {
        "enabled": { "type": "boolean" },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "path": { "type": "string" }
      }
    },
    "service": {
      "type": "object",
      "required": ["type", "port"],
      "properties": {
        "type": { "type": "string", "enum": ["ClusterIP", "NodePort", "LoadBalancer"] },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 }
      }
    },
    "serviceAccount": {
      "type": "object",
      "properties": {
        "create": { "type": "boolean" },
        "name": { "type": "string" },
        "automountServiceAccountToken": { "type": "boolean" }
      }
    },
    "ingress": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "className": { "type": "string" },
        "annotations": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        },
        "hosts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "host": { "type": "string" },
              "paths": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["path"],
                  "properties": {
                    "path": { "type": "string", "minLength": 1 },
                    "pathType": {
                      "type": "string",
                      "enum": ["Exact", "Prefix", "ImplementationSpecific"]
                    }
                  }
                }
              }
            }
          }
        },
        "tls": { "type": "array" }
      }
    },
    "networkPolicy": {
      "type": "object",
      "properties": { "enabled": { "type": "boolean" } }
    },
    "autoscaling": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "minReplicas": { "type": "integer", "minimum": 1 },
        "maxReplicas": { "type": "integer", "minimum": 1 },
        "targetCPUUtilizationPercentage": { "type": "integer", "minimum": 1, "maximum": 100 }
      }
    },
    "podDisruptionBudget": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "minAvailable": {
          "oneOf": [
            { "type": "integer", "minimum": 0 },
            { "type": "string", "pattern": "^(100|[0-9]{1,2})%$" }
          ]
        }
      }
    },
    "lifecycle": {
      "type": "object",
      "required": ["preStopSleepSeconds"],
      "properties": {
        "preStopSleepSeconds": { "type": "integer", "minimum": 0 }
      }
    },
    "terminationGracePeriodSeconds": { "type": "integer", "minimum": 0 },
    "topologySpreadConstraints": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["maxSkew", "topologyKey", "whenUnsatisfiable"],
        "properties": {
          "maxSkew": { "type": "integer", "minimum": 1 },
          "topologyKey": { "type": "string", "minLength": 1 },
          "whenUnsatisfiable": {
            "type": "string",
            "enum": ["DoNotSchedule", "ScheduleAnyway"]
          },
          "labelSelector": { "type": "object" },
          "minDomains": { "type": "integer", "minimum": 1 },
          "nodeAffinityPolicy": { "type": "string", "enum": ["Honor", "Ignore"] },
          "nodeTaintsPolicy": { "type": "string", "enum": ["Honor", "Ignore"] },
          "matchLabelKeys": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    }
  },
  "definitions": {
    "workerProbe": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "path", "periodSeconds", "timeoutSeconds", "failureThreshold"],
      "properties": {
        "enabled": { "type": "boolean" },
        "path": { "type": "string", "minLength": 1 },
        "periodSeconds": { "type": "integer", "minimum": 1 },
        "timeoutSeconds": { "type": "integer", "minimum": 1 },
        "failureThreshold": { "type": "integer", "minimum": 1 }
      }
    },
    "workerProbeWithDelay": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "path", "initialDelaySeconds", "periodSeconds", "timeoutSeconds", "failureThreshold"],
      "properties": {
        "enabled": { "type": "boolean" },
        "path": { "type": "string", "minLength": 1 },
        "initialDelaySeconds": { "type": "integer", "minimum": 0 },
        "periodSeconds": { "type": "integer", "minimum": 1 },
        "timeoutSeconds": { "type": "integer", "minimum": 1 },
        "failureThreshold": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
